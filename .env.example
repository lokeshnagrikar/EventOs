# ==========================================
# EventOS Local Development Environment Configuration
# ==========================================

# Database Connection Info
POSTGRES_PORT=5433
POSTGRES_USER=eventos_admin
POSTGRES_PASSWORD=eventos_secure_pass

# Redis Cache Port
REDIS_PORT=6379

# RabbitMQ Message Broker Ports & Credentials
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=eventos_guest
RABBITMQ_PASS=eventos_guest_pass

# Security & JWT Token Keys
JWT_SECRET_KEY=9a4f2c8d7e6b5a3f1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Cloudinary Integration (Required for media uploads)
# Default 'demo' configurations trigger mock media uploads using premium stock URLs.
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=demo_key
CLOUDINARY_API_SECRET=demo_secret

# Monitoring Port mapping
GRAFANA_PORT=3002
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE_ID/YOUR_CHANNEL_ID/YOUR_TOKEN_HERE
RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=6LfVWistAAAAAPqNUggTPWJ6UyCepnH6esLk9Xmx