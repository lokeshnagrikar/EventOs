# EventOS Frontend - Environment Variables

# The base URL of the API Gateway that routes to the microservices.
# Locally, this is typically set to the API Gateway port (8080).
# In production/deployment, this should point to your public domain API path.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Google reCAPTCHA v2 Checkbox site key
# Obtain this from the Google reCAPTCHA Admin Console (https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LfVWistAAAAAK806E9mY3QsN5pyWIEcPkavpk_b
